# Database
DATABASE_URL=postgres://user:pass@localhost:5432/agents_db
REDIS_URL=redis://127.0.0.1:6379/

# API
API_HOST=0.0.0.0
API_PORT=8080

# Worker
WORKER_POOL_SIZE=5
WORKER_ITEMS_PER_LOOP=1
WORKER_POLL_MS=1500
WORKER_ITEM_AFFINITY=0

# Harness
WORKER_AGENT_ID_PREFIX=harness-worker
WORKER_EFFORT_PER_ITEM=5
WORKER_COST_PER_ITEM=0.25
WORKER_DB_CONNECT_ATTEMPTS=24
WORKER_DB_CONNECT_BACKOFF_MS=500
WORKER_DB_SCHEMA_ATTEMPTS=24
WORKER_DB_SCHEMA_BACKOFF_MS=500
WORKER_APPEND_ATTEMPTS=4
WORKER_APPEND_BACKOFF_MS=500

# Auth/Secrets
JWT_SECRET=super_secret_key_change_me
